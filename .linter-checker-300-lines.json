{
  "max_file_lines": 300,
  "max_function_lines": 50,
  "include_extensions": [
    ".cs",
    ".go",
    ".java",
    ".js",
    ".jsx",
    ".kt",
    ".kts",
    ".php",
    ".py",
    ".rb",
    ".rs",
    ".swift",
    ".ts",
    ".tsx"
  ],
  "ignore": [
    ".git",
    ".svn",
    ".hg",
    ".build",
    ".dart_tool",
    ".gradle",
    ".next",
    ".nuxt",
    ".pytest_cache",
    ".tox",
    ".venv",
    "DerivedData",
    "Pods",
    "bin",
    "build",
    "coverage",
    "dist",
    "node_modules",
    "obj",
    "out",
    "target",
    "vendor",
    "linter-checker-300-lines.py",
    "ai-readability-check.py",
    "*.designer.cs",
    "*.generated.*",
    "*.g.cs",
    "*.g.swift",
    "*.gen.*",
    "*.min.js",
    "*.pb.*",
    "*.snap",
    "*.snapshot"
  ],
  "language_overrides": {}
}
