# Dedicated staging server only. Do not copy these values into /etc/mortris/env.
LISTEN_ADDR=127.0.0.1:8091
MORTRIS_DEPLOYMENT=staging
MORTRIS_SDK_TEST_MODE=1
MORTRIS_SDK_TEST_PROJECT=mortris-sdk-test
MORTRIS_SDK_TEST_TOKEN=replace-with-a-random-secret-at-least-16-bytes-long

# Use the staging database credentials, never the production DSNs.
MORTRIS_MIGRATOR_DSN=postgres://...
MORTRIS_WRITER_DSN=postgres://...
MORTRIS_READER_DSN=postgres://...
MORTRIS_DISK_PATH=/
